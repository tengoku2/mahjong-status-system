DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Comma-separated Discord user IDs that can manage VRC name mappings even without Manage Server permission.
DEVELOPER_USER_IDS=
# Optional: enables POST /api/matches for TANKI/external integrations.
# Send this value as Authorization: Bearer <key> or x-api-key.
EXTERNAL_API_KEY=
# Optional: register commands only to these guilds during development.
# Comma-separated. Example: GUILD_ID_1,GUILD_ID_2
DISCORD_GUILD_IDS=
# Backward-compatible single guild setting. Prefer DISCORD_GUILD_IDS.
DISCORD_GUILD_ID=
# PostgreSQL connection URL. For Aiven, include sslmode=require.
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/defaultdb?sslmode=require"
# Optional: source SQLite DB used by the one-time migration script.
SQLITE_DATABASE_PATH="prisma/dev.db"
