{
  "name": "mahjong-status",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "node scripts/start-production.mjs",
    "register": "tsx src/register-commands.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "local:smoke": "tsx scripts/smoke.ts",
